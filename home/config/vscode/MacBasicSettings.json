{
	"editor.autoIndent": "full",
	"editor.cursorBlinking": "phase",
	"editor.cursorSmoothCaretAnimation": true,
	"editor.cursorWidth": 2,
	"editor.fontLigatures": false,
	"editor.formatOnPaste": true,
	"editor.formatOnType": true,
	"editor.glyphMargin": true,
	"editor.hover.enabled": false,
	"editor.insertSpaces": true,
	"editor.lightbulb.enabled": false,
	"editor.links": false,
	"editor.minimap.enabled": false,
	"editor.minimap.showSlider": "always",
	"editor.mouseWheelZoom": false,
	"editor.multiCursorModifier": "ctrlCmd",
	"editor.occurrencesHighlight": false,
	"editor.renderControlCharacters": true,
	"editor.renderLineHighlight": "all",
	"editor.renderWhitespace": "all",
	"editor.roundedSelection": false,
	"editor.rulers": [
		72,
		80,
		100,
		120
	],
	"editor.scrollBeyondLastLine": false,
	"editor.selectionHighlight": false,
	"editor.showFoldingControls": "always",
	"editor.smoothScrolling": true,
	"editor.snippetSuggestions": "top",
	"editor.stablePeek": true,
	"editor.tabCompletion": "on",
	"editor.wordWrap": "on",
	"editor.wordWrapColumn": 100,
	"editor.wrappingIndent": "deepIndent",
	"files.associations": {
		"*.js": "javascriptreact",
		"*.jsx": "javascriptreact",
		"*.sublime-settings": "jsonc",
		"*.sublime-color-scheme": "jsonc",
		"*.hidden-color-scheme": "jsonc",
		"Brewfile": "ruby",
		"Caskfile": "ruby",
		"Caskfile_fonts": "ruby",
		"Tapfile": "ruby",
		"Kegfile": "ruby",
		"Masfile": "ruby",
		"Masfile_macos11": "ruby",
		".fzf": "shellscript",
		"aliases": "shellscript",
		"bash_login": "shellscript",
		"bash_profile": "shellscript",
		"bashrc": "shellscript",
		"bashrc_Apple_Terminal": "shellscript",
		"env": "shellscript",
		"exports": "shellscript",
		"exports-linux": "shellscript",
		"exports-macos": "shellscript",
		"exports-macos-fink-sw": "shellscript",
		"exports-macos-homebrew-home": "shellscript",
		"exports-macos-homebrew-opt": "shellscript",
		"exports-macos-homebrew-usrlocal": "shellscript",
		"exports-macos-pkgin-optpkg": "shellscript",
		"exports-macos-ports-opt": "shellscript",
		"exports-macos-ports-optlocal": "shellscript",
		"ffmpeg": "shellscript",
		"functions": "shellscript",
		"fzf": "shellscript",
		"lfrc": "shellscript",
		"login": "shellscript",
		"profile": "shellscript",
		"ssh_config": "shellscript",
		"sshd_config": "shellscript",
		"zlogin": "shellscript",
		"zprofile": "shellscript",
		"zshenv": "shellscript",
		"zshrc": "shellscript",
		"zshrc_Apple_Terminal": "shellscript",
	},
	"files.autoSave": "onFocusChange",
	"files.defaultLanguage": "plaintext",
	"files.eol": "\n",
	"files.exclude": {
		"**/.git": true,
		"**/.hg": true,
		"**/.idea": true,
		"**/.svn": true,
		"**/CVS": true,
		"**/.DS_Store": true,
		"**/.vscode": true
	},
	"files.insertFinalNewline": true,
	"files.trimFinalNewlines": true,
	"files.trimTrailingWhitespace": true,
	"workbench.activityBar.visible": false,
	"workbench.colorTheme": "Monokai Pro (Filter Spectrum)",
	"workbench.editor.closeOnFileDelete": true,
	"workbench.editor.highlightModifiedTabs": true,
	"workbench.editor.labelFormat": "short",
	"workbench.editor.tabSizing": "shrink",
	"workbench.fontAliasing": "auto",
	"workbench.iconTheme": "file-icons",
	"workbench.list.smoothScrolling": true,
	"workbench.startupEditor": "none",
	"workbench.statusBar.visible": true,
	"workbench.tree.indent": 13,
	"workbench.tree.renderIndentGuides": "always",
	"breadcrumbs.enabled": false,
	"breadcrumbs.symbolSortOrder": "name",
	"breadcrumbs.filePath": "on",
	"window.closeWhenEmpty": false,
	"window.openFilesInNewWindow": "off",
	"window.restoreFullscreen": true,
	"window.restoreWindows": "folders",
	"window.title": "${activeEditorLong}${separator}${rootPath}",
	"window.zoomLevel": 0,
	"explorer.compactFolders": false,
	"explorer.confirmDragAndDrop": false,
	"explorer.confirmDelete": false,
	"search.smartCase": true,
	"git.alwaysShowStagedChangesResourceGroup": true,
	"git.autofetch": true,
	"git.confirmSync": true,
	"git.enableCommitSigning": true,
	"git.enableSmartCommit": true,
	"git.promptToSaveFilesBeforeCommit": "always",
	"git.showPushSuccessNotification": true,
	"scm.diffDecorations": "all",
	"scm.diffDecorationsGutterWidth": 1,
	"terminal.external.linuxExec": "Terminator",
	"terminal.external.osxExec": "iTerm2.app",
	"terminal.integrated.cursorBlinking": true,
	"terminal.integrated.cursorStyle": "line",
	"terminal.integrated.fontFamily": "MesloLGSNerdFontComplete-Regular",
}
